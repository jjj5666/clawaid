<!DOCTYPE html>
<html lang="en" class="notranslate" translate="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="google" content="notranslate">
  <meta http-equiv="Content-Language" content="en, zh">
  <title>ClawAid</title>

  <style>
    /* ═══ CSS Variables ═══════════════════════════════════════════════════════ */
    :root {
      --bg:            #f8f8fa;
      --surface:       #ffffff;
      --surface-alt:   #f4f5f7;
      --border:        #e8e8ec;
      --border-strong: #d1d1d6;
      --text:          #1a1a1a;
      --text-secondary:#6b6b76;
      --text-muted:    #9b9ba4;

      --accent:        #4f46e5;
      --accent-hover:  #4338ca;
      --accent-bg:     #eef2ff;
      --accent-border: #c7d2fe;

      --green:         #059669;
      --green-bg:      #ecfdf5;
      --green-border:  #a7f3d0;

      --red:           #dc2626;
      --red-bg:        #fef2f2;
      --red-border:    #fecaca;

      --amber:         #d97706;
      --amber-bg:      #fffbeb;
      --amber-border:  #fde68a;

      --blue:          #2563eb;
      --blue-bg:       #eff6ff;
      --blue-border:   #bfdbfe;

      --radius:        14px;
      --radius-sm:     10px;
      --radius-xs:     6px;

      --shadow-sm:     0 1px 2px rgba(0,0,0,.04), 0 1px 3px rgba(0,0,0,.03);
      --shadow:        0 2px 6px rgba(0,0,0,.06), 0 1px 4px rgba(0,0,0,.04);
      --shadow-lg:     0 4px 16px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.04);

      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft YaHei',
              'PingFang SC', 'Noto Sans SC', sans-serif;
      --mono: 'SF Mono', 'Menlo', 'Consolas', 'Microsoft YaHei', monospace;

      --transition: 0.18s ease;
    }

    /* ═══ Reset ═══════════════════════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ═══ Base ════════════════════════════════════════════════════════════════ */
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 32px 16px 96px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ═══ Layout ══════════════════════════════════════════════════════════════ */
    .wrap { max-width: 520px; margin: 0 auto; }
    .hidden { display: none !important; }
    #feed { display: flex; flex-direction: column; gap: 12px; }

    /* ═══ Header ══════════════════════════════════════════════════════════════ */
    .hdr { text-align: center; margin-bottom: 28px; }
    .hdr-logo { font-size: 48px; line-height: 1; display: block; margin-bottom: 10px; }
    .hdr h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.4px; }
    .hdr-sub { font-size: 13px; color: var(--text-secondary); margin-top: 4px; }

    /* ═══ Cards ═══════════════════════════════════════════════════════════════ */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      animation: fadeUp .24s ease both;
    }

    /* ═══ Start Screen ═══════════════════════════════════════════════════════ */
    .start-card { padding: 28px 24px; }
    .start-card p { font-size: 14px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 12px; }
    .start-card ul { padding-left: 20px; font-size: 13px; color: var(--text-secondary); line-height: 2; margin-bottom: 20px; }
    .start-card ul li { list-style: disc; }

    /* ═══ Buttons ═════════════════════════════════════════════════════════════ */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      padding: 9px 18px; font-size: 13px; font-weight: 600; font-family: var(--font);
      border: none; border-radius: var(--radius-sm); cursor: pointer;
      transition: all var(--transition); white-space: nowrap; letter-spacing: -0.1px;
    }
    .btn:hover:not(:disabled) { transform: translateY(-0.5px); }
    .btn:active:not(:disabled) { transform: translateY(0) scale(.98); }
    .btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover:not(:disabled) { background: var(--accent-hover); }
    .btn-green { background: var(--green); color: #fff; }
    .btn-green:hover:not(:disabled) { background: #047857; }
    .btn-amber { background: var(--amber); color: #fff; }
    .btn-ghost {
      background: var(--surface); color: var(--text);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover:not(:disabled) { background: var(--surface-alt); border-color: var(--border-strong); }

    .btn-full { width: 100%; padding: 13px 20px; font-size: 15px; border-radius: var(--radius); }
    .btn-primary.btn-full { box-shadow: 0 1px 3px rgba(79,70,229,.25); }

    /* ═══ Spinner ═════════════════════════════════════════════════════════════ */
    .spin {
      width: 16px; height: 16px;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin .65s linear infinite;
      flex-shrink: 0; display: inline-block;
    }
    .spin-sm { width: 13px; height: 13px; border-width: 1.5px; }

    /* ═══ Scan Block ═════════════════════════════════════════════════════════ */
    .scan-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      animation: fadeUp .24s ease both;
    }
    .scan-hd {
      display: flex; align-items: center; gap: 14px;
      padding: 16px 20px;
    }
    .scan-emoji { font-size: 24px; flex-shrink: 0; }
    .scan-body { flex: 1; min-width: 0; }
    .scan-title { font-size: 14px; font-weight: 600; }
    .scan-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .scan-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .scan-toggle {
      font-size: 12px; color: var(--accent); background: none; border: none;
      cursor: pointer; padding: 2px 0; white-space: nowrap;
    }
    .scan-toggle:hover { text-decoration: underline; }
    .scan-details { border-top: 1px solid var(--border); padding: 10px 20px 14px; display: none; }
    .scan-details.open { display: block; }
    .schk { display: flex; align-items: center; gap: 10px; padding: 5px 0; font-size: 12px; color: var(--text-secondary); }
    .schk-icon { width: 16px; text-align: center; flex-shrink: 0; font-size: 13px; }
    .schk-icon.done { color: var(--green); }
    .schk-icon.pending { color: var(--text-muted); }
    .schk-text { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* ═══ Scan Checklist ══════════════════════════════════════════════════════ */
    .scan-checklist { }
    .scl-item {
      display: flex; align-items: center; gap: 10px;
      padding: 5px 20px; font-size: 12px;
      animation: fadeIn .22s ease both;
    }
    .scl-item:first-child { padding-top: 10px; border-top: 1px solid var(--border); }
    .scl-item:last-child  { padding-bottom: 12px; }
    .scl-icon { width: 20px; text-align: center; flex-shrink: 0; font-size: 13px; display: flex; align-items: center; justify-content: center; }
    .scl-label { flex: 1; color: var(--text-secondary); }
    .scl-label.pending { color: var(--accent); }
    .scl-label.error   { color: var(--red); }
    .scl-time { font-size: 11px; color: var(--text-muted); min-width: 34px; text-align: right; }

    /* ═══ AI Phase Card ════════════════════════════════════════════════════ */
    .ai-phase-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      animation: fadeUp .24s ease both;
    }
    .ai-phase-hd {
      display: flex; align-items: center; gap: 14px;
      padding: 16px 20px;
    }
    .ai-phase-emoji { font-size: 24px; flex-shrink: 0; animation: pulse-glow 2s ease-in-out infinite; }
    .ai-phase-emoji.done { animation: none; }
    .ai-phase-body { flex: 1; min-width: 0; }
    .ai-phase-title { font-size: 14px; font-weight: 600; }
    .ai-phase-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
    .ai-phase-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .ai-phase-steps {
      border-top: 1px solid var(--border);
      padding: 6px 0;
    }

    /* ═══ AI Step Item (READ / FIX / DONE inside phase card) ═══════════════ */
    .ai-step {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 8px 20px;
      font-size: 13px;
      animation: fadeIn .22s ease both;
    }
    .ai-step-icon {
      width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 1px;
    }
    .ai-step-body { flex: 1; min-width: 0; }
    .ai-step-desc { font-weight: 500; color: var(--text); line-height: 1.4; }
    .ai-step-desc.pending { color: var(--accent); }
    .ai-step-cmd {
      font-family: var(--mono); font-size: 11px; color: var(--text-muted);
      margin-top: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .ai-step-output {
      font-family: var(--mono); font-size: 11px; color: var(--text-secondary);
      background: var(--surface-alt); border: 1px solid var(--border);
      border-radius: var(--radius-xs); padding: 8px 10px;
      margin-top: 6px; max-height: 120px; overflow-y: auto;
      white-space: pre-wrap; word-break: break-all; line-height: 1.45;
      display: none;
    }
    .ai-step-output.visible { display: block; }
    .ai-step-toggle {
      font-size: 11px; color: var(--text-muted); background: none; border: none;
      cursor: pointer; padding: 2px 0; margin-top: 4px; font-family: var(--font);
    }
    .ai-step-toggle:hover { color: var(--accent); }
    .ai-step-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    .ai-step-time { font-size: 11px; color: var(--text-muted); flex-shrink: 0; margin-top: 2px; min-width: 30px; text-align: right; }
    @keyframes pulse-glow {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.1); opacity: .8; }
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: .4; transform: scale(.7); }
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ═══ Fix Step Cards ══════════════════════════════════════════════════════ */
    .fix-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      animation: fadeUp .24s ease both;
    }
    .fix-hd {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 18px; cursor: pointer; user-select: none;
      transition: background var(--transition);
    }
    .fix-hd:hover { background: var(--surface-alt); }
    .fix-icon { font-size: 20px; width: 26px; text-align: center; flex-shrink: 0; }
    .fix-info { flex: 1; min-width: 0; }
    .fix-title { font-size: 14px; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .fix-badges { display: flex; gap: 5px; margin-top: 3px; flex-wrap: wrap; }

    .badge {
      font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 5px;
      text-transform: uppercase; letter-spacing: .3px;
    }
    .badge-fix    { background: var(--amber-bg); color: var(--amber); }
    .badge-medium { background: var(--amber-bg); color: var(--amber); }
    .badge-high   { background: var(--red-bg);   color: var(--red); }
    .badge-done   { background: var(--green-bg); color: var(--green); }

    .fix-status { font-size: 16px; flex-shrink: 0; }
    .fix-detail { display: none; border-top: 1px solid var(--border); padding: 14px 18px; }
    .fix-card.open .fix-detail { display: block; }

    .fix-reason { font-size: 13px; color: var(--text-secondary); line-height: 1.55; margin-bottom: 10px; }
    .fix-cmd {
      font-family: var(--mono); font-size: 12px;
      background: var(--surface-alt); border: 1px solid var(--border);
      border-radius: var(--radius-xs); padding: 9px 12px;
      color: var(--text-secondary); word-break: break-all; margin-bottom: 10px;
    }
    .fix-output-label {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .6px; color: var(--text-muted); margin-bottom: 4px;
    }
    .fix-output {
      font-family: var(--mono); font-size: 11px;
      background: var(--surface-alt); border: 1px solid var(--border);
      border-radius: var(--radius-xs); padding: 9px 12px;
      color: var(--text-secondary); max-height: 180px; overflow-y: auto;
      white-space: pre-wrap; word-break: break-all; line-height: 1.5;
    }
    .fix-thinking-btn {
      font-size: 12px; color: var(--text-muted); cursor: pointer;
      margin-bottom: 8px; user-select: none; text-decoration: underline dotted;
      background: none; border: none; padding: 0; font-family: var(--font);
    }
    .fix-thinking-btn:hover { color: var(--text-secondary); }
    .fix-thinking-text {
      display: none; font-size: 12px; color: var(--text-muted);
      background: var(--surface-alt); border: 1px solid var(--border);
      border-radius: var(--radius-xs); padding: 9px 12px;
      margin-bottom: 10px; white-space: pre-wrap; word-break: break-word; line-height: 1.55;
    }

    /* ═══ Confirm Bar ════════════════════════════════════════════════════════ */
    .confirm-bar {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 18px; background: var(--amber-bg);
      border-top: 1px solid var(--amber-border);
    }
    .confirm-bar.risk-high { background: var(--red-bg); border-top-color: var(--red-border); }
    .confirm-label { font-size: 13px; color: var(--text); flex: 1; font-weight: 500; }

    /* ═══ Result Cards ════════════════════════════════════════════════════════ */
    .result-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 32px 28px 24px;
      text-align: center;
      animation: fadeUp .32s ease both;
    }
    .result-icon { font-size: 52px; line-height: 1; display: block; margin-bottom: 14px; }
    .result-title { font-size: 22px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 16px; }

    .result-meta {
      text-align: left; background: var(--surface-alt);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      padding: 14px 16px; margin-bottom: 18px;
    }
    .rmr { display: flex; gap: 10px; font-size: 13px; line-height: 1.55; }
    .rmr + .rmr { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
    .rmr-label { font-weight: 600; color: var(--text-secondary); flex-shrink: 0; min-width: 56px; }
    .rmr-value { color: var(--text); }

    .problem-box {
      text-align: left; border-radius: var(--radius-sm);
      padding: 14px 16px; margin-bottom: 18px; font-size: 13px; line-height: 1.6;
    }
    .problem-box-amber { background: var(--amber-bg); border: 1px solid var(--amber-border); border-left: 4px solid var(--amber); }
    .problem-box-red { background: var(--red-bg); border: 1px solid var(--red-border); border-left: 4px solid var(--red); }
    .problem-box-label { font-weight: 700; color: var(--text-secondary); font-size: 11px; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 5px; }

    .contact-block {
      font-size: 13px; color: var(--text-secondary); line-height: 1.7;
      padding: 14px 16px; background: var(--surface-alt);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      text-align: left; margin-bottom: 16px;
    }
    .contact-block b { color: var(--text); }

    /* ═══ Warning Cards ══════════════════════════════════════════════════════ */
    .warnings-section { text-align: left; margin-bottom: 18px; }
    .warnings-heading {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .7px; color: var(--text-muted);
      margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
    }
    .wc {
      background: var(--surface); border: 1px solid var(--border); border-left-width: 4px;
      border-radius: var(--radius-sm); padding: 14px 16px 12px; margin-bottom: 8px;
      box-shadow: var(--shadow-sm); animation: fadeUp .2s ease both; overflow: hidden;
      transition: opacity .25s, transform .25s, max-height .35s ease .15s, margin .35s ease .15s, padding .35s ease .15s;
    }
    .wc:last-child { margin-bottom: 0; }
    .wc-fix    { border-left-color: var(--amber); }
    .wc-review { border-left-color: var(--blue); }
    .wc-ignore { border-left-color: var(--border-strong); background: var(--surface-alt); opacity: .85; }

    .wc-hd { display: flex; align-items: flex-start; gap: 10px; }
    .wc-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
    .wc-title { font-size: 13px; font-weight: 600; flex: 1; line-height: 1.5; }
    .wc-ignorable {
      font-size: 10px; font-weight: 600; color: var(--text-muted);
      background: var(--border); border-radius: 4px; padding: 1px 6px;
      flex-shrink: 0; margin-top: 2px;
    }
    .wc-dismiss {
      background: none; border: none; cursor: pointer; font-size: 14px;
      color: var(--text-muted); line-height: 1; padding: 0 0 0 4px;
      flex-shrink: 0; margin-top: 1px; transition: color var(--transition);
    }
    .wc-dismiss:hover { color: var(--text); }
    .wc-reason { font-size: 12px; color: var(--text-secondary); margin-top: 6px; line-height: 1.55; padding-left: 26px; }

    .wc-actions { margin-top: 10px; padding-left: 26px; display: flex; flex-wrap: wrap; gap: 6px; }
    .wc-action-btn {
      font-size: 12px; font-weight: 600; padding: 5px 14px;
      border-radius: 100px; cursor: pointer; transition: all var(--transition);
      font-family: var(--font); border: 1px solid var(--border);
    }
    .wc-action-primary { background: var(--amber-bg); border-color: var(--amber-border); color: var(--amber); }
    .wc-action-primary:hover { background: #fef3c7; }
    .wc-action-secondary { background: var(--surface); color: var(--text-secondary); }
    .wc-action-secondary:hover { background: var(--surface-alt); }
    .wc-action-btn.copied { color: var(--green); border-color: var(--green-border); background: var(--green-bg); }

    .wc-code-area { display: flex; align-items: center; gap: 6px; margin-top: 8px; padding-left: 26px; }
    .wc-code {
      font-family: var(--mono); font-size: 11px;
      background: var(--surface-alt); border: 1px solid var(--border);
      border-radius: var(--radius-xs); padding: 5px 9px;
      color: var(--text-secondary); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .wc-copy {
      background: none; border: 1px solid var(--border); border-radius: var(--radius-xs);
      padding: 4px 9px; font-size: 12px; cursor: pointer; flex-shrink: 0;
      color: var(--text-secondary); transition: all var(--transition);
    }
    .wc-copy:hover { background: var(--surface-alt); }
    .wc-copy.copied { color: var(--green); border-color: var(--green-border); }

    /* ═══ Feedback ════════════════════════════════════════════════════════════ */
    .fb-card {
      background: var(--surface-alt); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 18px 20px; text-align: center;
      margin-top: 18px; margin-bottom: 6px;
    }
    .fb-q { font-size: 13px; color: var(--text-secondary); margin-bottom: 12px; font-weight: 500; }
    .fb-btns { display: flex; gap: 8px; transition: opacity .25s, transform .25s; }
    .fb-btns .btn { flex: 1; }
    .fb-done { display: none; }
    .fb-done.visible { display: block; animation: fadeUp .28s ease both; }
    .fb-emoji { font-size: 32px; margin-bottom: 8px; display: block; }
    .fb-text { font-size: 14px; font-weight: 600; margin-bottom: 6px; }
    .fb-contact { font-size: 12px; color: var(--text-muted); line-height: 1.6; }
    .fb-contact b { color: var(--text-secondary); }

    /* ═══ Feedback Gate ════════════════════════════════════════════════════════ */
    .feedback-gate {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 36px 28px 32px;
      text-align: center;
      animation: fadeUp .32s ease both;
    }
    .fb-gate-emoji { font-size: 40px; display: block; margin-bottom: 14px; }
    .fb-gate-q { font-size: 18px; font-weight: 600; margin-bottom: 28px; letter-spacing: -0.2px; }
    .fb-gate-btns { display: flex; gap: 14px; justify-content: center; }
    .fb-gate-btn {
      flex: 1; max-width: 210px; padding: 15px 20px; font-size: 15px; font-weight: 600;
      font-family: var(--font); border-radius: var(--radius); cursor: pointer;
      border: 2px solid transparent; transition: all var(--transition);
      display: inline-flex; align-items: center; justify-content: center;
    }
    .fb-gate-btn:hover { transform: translateY(-1px); }
    .fb-gate-btn:active { transform: translateY(0) scale(.98); }
    .fb-gate-btn-yes { background: var(--green); color: #fff; box-shadow: 0 2px 8px rgba(5,150,105,.25); }
    .fb-gate-btn-yes:hover { background: #047857; }
    .fb-gate-btn-no { background: var(--surface); color: var(--text); border-color: var(--border-strong); }
    .fb-gate-btn-no:hover { background: var(--surface-alt); }
    .fb-gate-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .fb-gate-detail { margin-top: 20px; text-align: left; animation: fadeUp .2s ease both; }
    .fb-gate-detail-label { font-size: 13px; color: var(--text-secondary); margin-bottom: 8px; font-weight: 500; }
    .fb-gate-detail textarea {
      width: 100%; padding: 10px 12px; font-size: 13px; font-family: var(--font);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      resize: vertical; min-height: 72px; background: var(--surface); color: var(--text);
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .fb-gate-detail textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,70,229,.1); }
    .fb-gate-detail-row { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }

    /* ═══ Description Input ═══════════════════════════════════════════════════ */
    .input-card { padding: 24px 22px; }
    .input-title { font-size: 17px; font-weight: 600; margin-bottom: 5px; }
    .input-hint { font-size: 13px; color: var(--text-secondary); margin-bottom: 16px; line-height: 1.55; }
    .input-textarea-wrap { position: relative; margin-bottom: 10px; }
    .input-textarea {
      width: 100%; padding: 12px 14px 38px; font-size: 14px;
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      font-family: var(--font); resize: vertical; min-height: 92px;
      line-height: 1.55; background: var(--surface); color: var(--text);
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .input-textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,70,229,.1); }
    .input-textarea::placeholder { color: var(--text-muted); }
    .input-camera {
      position: absolute; bottom: 9px; right: 9px;
      background: none; border: none; cursor: pointer; font-size: 18px;
      color: var(--text-muted); border-radius: var(--radius-xs); padding: 3px;
      transition: all var(--transition);
    }
    .input-camera:hover { color: var(--text); background: var(--border); }
    .input-camera.has-img { color: var(--green); }

    .ss-preview {
      display: none; align-items: center; gap: 10px; margin-bottom: 10px;
      padding: 8px 12px; background: var(--green-bg); border: 1px solid var(--green-border);
      border-radius: var(--radius-sm); font-size: 12px; color: var(--green);
    }
    .ss-preview.visible { display: flex; }
    .ss-preview img { height: 38px; border-radius: 5px; }
    .ss-preview-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ss-preview-rm { background: none; border: none; cursor: pointer; font-size: 14px; color: var(--text-muted); transition: color var(--transition); }
    .ss-preview-rm:hover { color: var(--red); }

    .btn-row { display: flex; gap: 8px; margin-top: 12px; }
    .btn-row .btn { flex: 1; }

    /* ═══ Paywall ═════════════════════════════════════════════════════════════ */
    .pw-card { padding: 28px 24px; }
    .pw-hd { text-align: center; margin-bottom: 22px; }
    .pw-emoji { font-size: 40px; display: block; margin-bottom: 10px; }
    .pw-title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
    .pw-sub { font-size: 13px; color: var(--text-secondary); }
    .pw-price-box { text-align: center; margin-bottom: 22px; }
    .pw-price { font-size: 36px; font-weight: 700; color: var(--accent); line-height: 1; }
    .pw-price-sub { font-size: 13px; color: var(--text-muted); margin-top: 5px; }
    .pw-divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }
    .pw-auto-detect {
      display: none; text-align: center; padding: 10px 16px; margin-top: 12px;
      background: var(--accent-bg); border: 1px solid var(--accent-border);
      border-radius: var(--radius-sm); font-size: 13px; color: var(--accent);
    }
    .pw-msg { font-size: 12px; text-align: center; margin-top: 10px; min-height: 18px; }
    .pw-contact { text-align: center; margin-top: 18px; font-size: 12px; color: var(--text-muted); line-height: 1.6; }
    .pw-input {
      width: 100%; padding: 10px 14px; font-size: 14px; font-family: var(--mono);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      background: var(--surface); color: var(--text); margin-bottom: 8px;
    }
    .pw-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,70,229,.1); }

    /* ═══ Toast ═══════════════════════════════════════════════════════════════ */
    #toast {
      position: fixed; bottom: 28px; left: 50%;
      transform: translateX(-50%) translateY(0);
      background: #1a1a1a; color: #fff;
      font-size: 13px; font-weight: 500; font-family: var(--font);
      padding: 9px 20px; border-radius: 100px;
      box-shadow: var(--shadow-lg); opacity: 0; pointer-events: none;
      transition: opacity .3s, transform .3s; z-index: 9999; white-space: nowrap;
    }
    #toast.show { opacity: 1; transform: translateX(-50%) translateY(-4px); }

    /* ═══ Confetti ════════════════════════════════════════════════════════════ */
    #confetti { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 8000; overflow: hidden; }
    .confetti-p { position: absolute; top: -24px; will-change: transform, opacity; }
    @keyframes confetti-fall {
      0%   { transform: translateY(-24px) rotate(0deg) scale(1); opacity: 1; }
      75%  { opacity: 1; }
      100% { transform: translateY(110vh) rotate(800deg) scale(.7); opacity: 0; }
    }

    /* ═══ Footer ══════════════════════════════════════════════════════════════ */
    .footer { text-align: center; font-size: 12px; color: var(--text-muted); margin-top: 36px; }

    /* ═══ Animations ═════════════════════════════════════════════════════════ */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }

    /* ═══ Anti-garbling ══════════════════════════════════════════════════════ */
    code, .fix-cmd, .fix-output, .wc-code, .pw-input, [translate="no"] {
      font-family: var(--mono) !important;
    }

    /* ═══ Dark Mode ══════════════════════════════════════════════════════════ */
    @media (prefers-color-scheme: dark) {
      :root {
        --bg:            #0c0c0e;
        --surface:       #18181b;
        --surface-alt:   #1f1f24;
        --border:        #2a2a30;
        --border-strong: #3a3a42;
        --text:          #f0f0f2;
        --text-secondary:#8a8a96;
        --text-muted:    #555560;

        --accent:        #818cf8;
        --accent-hover:  #6366f1;
        --accent-bg:     rgba(99,102,241,.12);
        --accent-border: rgba(129,140,248,.25);

        --green-bg:      rgba(5,150,105,.1);
        --green-border:  rgba(52,211,153,.2);
        --red-bg:        rgba(220,38,38,.1);
        --red-border:    rgba(252,165,165,.15);
        --amber-bg:      rgba(217,119,6,.1);
        --amber-border:  rgba(253,230,138,.15);
        --blue-bg:       rgba(37,99,235,.1);
        --blue-border:   rgba(147,197,253,.15);
      }
      .wc-ignore { background: #141416; }
      .fix-cmd, .fix-output, .wc-code { background: #111113; }
      #toast { background: #f0f0f2; color: #111; }
    }

    /* ═══ Mobile ═════════════════════════════════════════════════════════════ */
    @media (max-width: 480px) {
      body { padding: 22px 12px 72px; }
      .result-card { padding: 26px 20px 20px; }
      .start-card  { padding: 22px 18px; }
      .hdr-logo    { font-size: 42px; }
      .hdr h1      { font-size: 20px; }
    }
  </style>
</head>
<body>

<div id="confetti" aria-hidden="true"></div>
<div id="toast"></div>

<div class="wrap notranslate">

  <!-- Header -->
  <div class="hdr">
    <span class="hdr-logo">🦞🩹</span>
    <h1>ClawAid</h1>
    <p class="hdr-sub" id="hdr-sub">Automatic diagnostics &amp; repair for OpenClaw</p>
  </div>

  <!-- Start screen -->
  <div id="start-screen">
    <div class="card start-card">
      <p id="privacy-text">ClawAid reads your OpenClaw config, gateway status, and logs to find and fix problems.</p>
      <ul id="privacy-list">
        <li>API keys are redacted before leaving your machine</li>
        <li>Data is sent to our diagnostic service — never stored</li>
        <li>All commands run locally on your machine</li>
      </ul>
      <button class="btn btn-primary btn-full" id="btn-start">🩺 Start Scan</button>
    </div>
  </div>

  <!-- Steps feed -->
  <div id="feed" class="hidden"></div>

  <div class="footer">ClawAid v1.1.28</div>

</div>

<script>
(function () {
  'use strict';

  // ═══ State ════════════════════════════════════════════════════════════════
  let sessionId = null;
  let sbSessionId = null;
  let eventSource = null;
  let scanBlockAdded = false;
  let currentStepIndex = -1;
  const stepTypes = {};
  const sCheckEls = {};
  var scanStartTime = 0;
  var scanTimerInterval = null;
  var scanChecklistItems = {};
  var scanItemStartTimes = {};

  const feed = document.getElementById('feed');
  const startScreen = document.getElementById('start-screen');

  // ═══ i18n ═════════════════════════════════════════════════════════════════
  const isZh = /^zh/i.test(navigator.language || '');

  const T = {
    startScan:       isZh ? '🩺 开始扫描' : '🩺 Start Scan',
    subtitle:        isZh ? '自动诊断并修复 OpenClaw' : 'Automatic diagnostics & repair for OpenClaw',
    privacy:         isZh ? 'ClawAid 会读取你的 OpenClaw 配置、gateway 状态和日志来诊断问题。' : 'ClawAid reads your OpenClaw config, gateway status, and logs to find and fix problems.',
    privacyList:     isZh
      ? ['API 密钥在发送前已脱敏', '数据发送到诊断服务，不会存储', '所有命令在你的本机执行']
      : ['API keys are redacted before leaving your machine', 'Data is sent to our diagnostic service — never stored', 'All commands run locally on your machine'],
    scanning:        isZh ? '正在诊断...' : 'Diagnosing...',
    scanned:         isZh ? '系统检测完成' : 'System checked',
    viewDetails:     isZh ? '查看详情' : 'View details',
    hideDetails:     isZh ? '收起' : 'Collapse',
    allClear:        isZh ? '一切正常！' : 'All clear!',
    fixed:           isZh ? '已修复！' : 'Fixed!',
    notFixed:        isZh ? '无法自动修复' : "Couldn't fix automatically",
    degradedTitle:   isZh ? '系统在运行但存在问题' : 'Running, but with issues',
    scanAgain:       isZh ? '🔄 重新扫描' : '🔄 Scan Again',
    tryAgain:        isZh ? '🔄 再试一次' : '🔄 Try Again',
    findingsTitle:   isZh ? '其他发现' : 'Other findings',
    suggestionsTitle:isZh ? '建议' : 'Suggestions',
    wasHelpful:      isZh ? '问题解决了吗？' : 'Was this helpful?',
    feedbackYes:     isZh ? '👍 解决了' : '👍 Yes',
    feedbackNo:      isZh ? '👎 没解决' : '👎 No',
    thanksYes:       isZh ? '太好了！很高兴帮到你' : 'Great! Glad it helped.',
    thanksNo:        isZh ? '抱歉没解决<br><span style="font-size:14px;margin-top:8px;display:inline-block;">WeChat: <b>oliver56666</b> · <a href="https://github.com/jjj5666/clawaid/issues" target="_blank">GitHub Issues</a></span>' : 'Sorry about that<br><span style="font-size:14px;margin-top:8px;display:inline-block;">WeChat: <b>oliver56666</b> · <a href="https://github.com/jjj5666/clawaid/issues" target="_blank">GitHub Issues</a></span>',
    contact:         isZh ? '有问题？' : 'Questions?',
    allowQ:          isZh ? '这将修改你的系统，允许执行吗？' : 'This will modify your system. Allow?',
    allow:           isZh ? '✓ 允许' : '✓ Allow',
    skip:            isZh ? '跳过' : 'Skip',
    whatsWrong:      isZh ? '遇到什么问题？' : "What's going on?",
    descHint:        isZh ? '描述你的问题，或直接扫描——ClawAid 会自动诊断。' : 'Describe the problem, or just scan — ClawAid will figure it out.',
    descPlaceholder: isZh ? '例如：更新后 OpenClaw 就不响应了...（可选）' : 'e.g. OpenClaw stopped responding after I updated... (optional)',
    sendDiagnose:    isZh ? '📝 发送并诊断' : '📝 Send & diagnose',
    justScan:        isZh ? '🔍 直接扫描修复' : '🔍 Just scan & fix',
    problem:         isZh ? '问题' : 'Problem',
    fixedLabel:      isZh ? '修复' : 'Fixed',
    quickFix:        isZh ? '⚡ 一键修复' : '⚡ Quick fix',
    copied:          isZh ? '✓ 已复制' : '✓ Copied',
    ignorable:       isZh ? '可忽略' : 'Ignorable',
    showThinking:    isZh ? '💭 查看 AI 推理' : '💭 Show AI reasoning',
    hideThinking:    isZh ? '▲ 收起' : '▲ Hide',
    connLost:        isZh ? '连接中断' : 'Connection lost',
    serverStopped:   isZh ? '服务器可能已停止。' : 'The server may have stopped.',
    retry:           isZh ? '🔄 重试' : '🔄 Retry',
    error:           isZh ? '出错了' : 'Error',
    pwFreeUsed:      isZh ? '免费次数已用完' : 'Free scans used up',
    pwGetPack:       isZh ? '购买修复包继续使用' : 'Get a fix pack to continue',
    pwFixesPer:      (n) => isZh ? `${n} 次修复 · 修不好不扣次` : `${n} fixes · only charged on success`,
    pwBuyNow:        isZh ? '💳 立即购买' : '💳 Buy Now',
    pwWaiting:       isZh ? '等待支付完成，完成后自动激活...' : 'Waiting for payment — will activate automatically...',
    pwAutoTimeout:   isZh ? '自动检测超时，请手动输入激活码' : 'Auto-detect timed out. Please enter your token manually.',
    pwPaySuccess:    isZh ? '✅ 支付成功！自动激活中...' : '✅ Payment received! Activating...',
    pwHaveToken:     isZh ? '已有激活码？点击输入' : 'Already have a token? Click here',
    pwTokenHint:     isZh ? '激活码 CA-XXXX 或购买邮箱' : 'Token CA-XXXX or purchase email',
    pwActivate:      isZh ? '🔑 激活' : '🔑 Activate',
    pwChecking:      isZh ? '验证中...' : 'Checking...',
    pwSuccess:       isZh ? '✅ 激活成功！重新扫描中...' : '✅ Activated! Restarting scan...',
    pwEnterToken:    isZh ? '请输入激活码或邮箱' : 'Enter your token or email.',
    pwInvalid:       isZh ? '❌ 无效的激活码或邮箱' : '❌ Invalid token or email.',
    pwNetErr:        isZh ? '❌ 网络错误' : '❌ Network error.',
    pwNeedHelp:      isZh ? '有问题？' : 'Need help?',
  };

  // Checklist label map — keyed by progress id from observe.ts
  var checkLabels = {
    status:   isZh ? 'OpenClaw 状态'  : 'OpenClaw status',
    gateway:  isZh ? 'Gateway 健康'   : 'Gateway health',
    doctor:   isZh ? '官方诊断'       : 'Doctor check',
    config:   isZh ? '配置 & 启动项'  : 'Config & launch agent',
    logs:     isZh ? '系统日志'       : 'System logs',
    devices:  isZh ? '设备配对'       : 'Device pairing',
    versions: isZh ? '版本检查'       : 'Version check',
    sessions: isZh ? '会话完整性'     : 'Session integrity',
    rules:    isZh ? '规则引擎'       : 'Rule engine',
  };

  // Apply i18n to static HTML
  document.getElementById('hdr-sub').textContent = T.subtitle;
  if (isZh) {
    document.getElementById('privacy-text').textContent = T.privacy;
    document.getElementById('privacy-list').innerHTML = T.privacyList.map(t => '<li>' + t + '</li>').join('');
  }
  document.getElementById('btn-start').textContent = T.startScan;

  // ═══ Helpers ══════════════════════════════════════════════════════════════
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function ev(name, data) { fetch('/api/event', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ event: name, data: data || {}, ts: Date.now() }) }).catch(function(){}); }
  // Compat alias
  function mp(name, p) { ev(name, p); }
  function scrollDown() { window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' }); }

  var toastTimer = null;
  function showToast(msg) {
    var t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function() { t.classList.remove('show'); }, 2400);
  }

  // ═══ Confetti ═════════════════════════════════════════════════════════════
  function triggerConfetti() {
    var c = document.getElementById('confetti'); c.innerHTML = '';
    var colors = ['#4f46e5','#059669','#d97706','#dc2626','#7c3aed','#0891b2','#f59e0b','#ec4899','#10b981'];
    for (var i = 0; i < 75; i++) {
      var p = document.createElement('div');
      p.className = 'confetti-p';
      var color = colors[Math.floor(Math.random() * colors.length)];
      var w = 5 + Math.random() * 7, h = 9 + Math.random() * 13;
      var left = Math.random() * 100;
      var dur = 1.6 + Math.random() * 2.2, delay = Math.random() * 1.8;
      var r = Math.random() > .45 ? '50%' : '2px';
      p.style.cssText = 'left:'+left+'%;width:'+w+'px;height:'+h+'px;background:'+color+';border-radius:'+r+';animation:confetti-fall '+dur+'s ease-in '+delay+'s both;transform:rotate('+Math.floor(Math.random()*360)+'deg)';
      c.appendChild(p);
    }
    setTimeout(function() { c.innerHTML = ''; }, 6000);
  }

  // ═══ Scan Block ═══════════════════════════════════════════════════════════
  function addScanBlock() {
    var el = document.createElement('div');
    el.className = 'scan-block'; el.id = 'scan-block';
    el.innerHTML = '<div class="scan-hd">'
      + '<div class="scan-emoji">📡</div>'
      + '<div class="scan-body">'
      +   '<div class="scan-title" id="scan-title">' + T.scanning + '</div>'
      +   '<div class="scan-sub" id="scan-sub">0.0s</div>'
      + '</div>'
      + '<div class="scan-right">'
      +   '<div id="scan-status"><div class="spin spin-sm"></div></div>'
      +   '<button class="scan-toggle" id="scan-toggle">' + T.viewDetails + '</button>'
      + '</div>'
      + '</div>'
      + '<div id="scan-checklist" class="scan-checklist"></div>'
      + '<div class="scan-details" id="scan-details"></div>';
    feed.appendChild(el);
    document.getElementById('scan-toggle').addEventListener('click', function() {
      var d = document.getElementById('scan-details');
      var open = d.classList.toggle('open');
      this.textContent = open ? T.hideDetails : T.viewDetails;
    });
    // Start elapsed time timer
    scanStartTime = Date.now();
    scanChecklistItems = {};
    scanItemStartTimes = {};
    scanTimerInterval = setInterval(function() {
      var sub = document.getElementById('scan-sub');
      if (sub) sub.textContent = ((Date.now() - scanStartTime) / 1000).toFixed(1) + 's';
    }, 100);
    scrollDown();
  }

  function updateScanProgress(data) {
    // Legacy string message — ignored, scan-sub is controlled by the timer
    if (!data || !data.id) return;

    var checklist = document.getElementById('scan-checklist');

    if (data.id === 'ai-analyze') {
      if (data.status === 'pending') {
        // Ensure AI phase card exists when AI starts
        ensureAiPhaseCard();
      }
      return;
    }

    if (!checklist) return;

    var label = checkLabels[data.id] || data.label || data.id;

    if (data.status === 'pending') {
      // Create checklist item
      var item = document.createElement('div');
      item.className = 'scl-item';
      item.id = 'scl-' + data.id;
      item.innerHTML = '<span class="scl-icon"><div class="spin spin-sm"></div></span>'
        + '<span class="scl-label pending">' + esc(label) + '</span>'
        + '<span class="scl-time" id="scl-t-' + data.id + '"></span>';
      checklist.appendChild(item);
      scanChecklistItems[data.id] = item;
      scanItemStartTimes[data.id] = Date.now();
      scrollDown();
    } else if (data.status === 'done' || data.status === 'error') {
      var existing = document.getElementById('scl-' + data.id);
      if (!existing) return;
      var elapsed = scanItemStartTimes[data.id]
        ? ((Date.now() - scanItemStartTimes[data.id]) / 1000).toFixed(1) + 's'
        : '';
      var isDone = data.status === 'done';
      var iconHtml = isDone
        ? '<span style="color:var(--green);font-size:13px">✓</span>'
        : '<span style="color:var(--red);font-size:13px">✗</span>';
      var labelClass = isDone ? 'scl-label' : 'scl-label error';
      existing.innerHTML = '<span class="scl-icon">' + iconHtml + '</span>'
        + '<span class="' + labelClass + '">' + esc(label) + '</span>'
        + '<span class="scl-time">' + esc(elapsed) + '</span>';
    }
  }

  // ═══ AI Phase Card — shows every READ/FIX step in the main feed ════════
  var aiStepStartTimes = {};

  function ensureAiPhaseCard() {
    if (document.getElementById('ai-phase-card')) return;
    var card = document.createElement('div');
    card.className = 'ai-phase-card';
    card.id = 'ai-phase-card';
    var title = isZh ? 'AI 正在诊断...' : 'AI diagnosing...';
    var sub = isZh ? '分析数据 → 定位问题 → 执行修复' : 'Analyze → Locate → Fix';
    card.innerHTML = '<div class="ai-phase-hd">'
      + '<div class="ai-phase-emoji" id="ai-phase-emoji">🧠</div>'
      + '<div class="ai-phase-body">'
      +   '<div class="ai-phase-title" id="ai-phase-title">' + title + '</div>'
      +   '<div class="ai-phase-sub" id="ai-phase-sub">' + sub + '</div>'
      + '</div>'
      + '<div class="ai-phase-right" id="ai-phase-status"><div class="spin spin-sm"></div></div>'
      + '</div>'
      + '<div class="ai-phase-steps" id="ai-phase-steps"></div>';
    feed.appendChild(card);
    scrollDown();
  }

  function finishAiPhaseCard() {
    var emoji = document.getElementById('ai-phase-emoji');
    if (emoji) { emoji.textContent = '🧠'; emoji.classList.add('done'); }
    var st = document.getElementById('ai-phase-status');
    if (st) st.innerHTML = '<span style="font-size:16px;color:var(--green)">✓</span>';
    var title = document.getElementById('ai-phase-title');
    if (title) title.textContent = isZh ? 'AI 诊断完成' : 'AI diagnosis complete';
    var sub = document.getElementById('ai-phase-sub');
    if (sub) sub.textContent = '';
  }

  function addAiStep(step, idx) {
    ensureAiPhaseCard();
    var container = document.getElementById('ai-phase-steps');
    if (!container) return;

    var isRead = step.type === 'read';
    var icon = isRead ? '<div class="spin spin-sm"></div>' : '🔧';
    var desc = step.description || step.command || (isRead ? 'Reading...' : 'Fixing...');
    var cmdHtml = step.command ? '<div class="ai-step-cmd" translate="no">$ ' + esc(step.command) + '</div>' : '';

    var row = document.createElement('div');
    row.className = 'ai-step';
    row.id = 'ai-step-' + idx;
    row.innerHTML = '<div class="ai-step-icon" id="ai-step-icon-' + idx + '">' + icon + '</div>'
      + '<div class="ai-step-body">'
      +   '<div class="ai-step-desc' + (isRead ? ' pending' : '') + '" id="ai-step-desc-' + idx + '">' + esc(desc) + '</div>'
      +   cmdHtml
      +   '<div class="ai-step-output" id="ai-step-out-' + idx + '"></div>'
      + '</div>'
      + '<div class="ai-step-time" id="ai-step-time-' + idx + '"></div>';
    container.appendChild(row);
    aiStepStartTimes[idx] = Date.now();
    scrollDown();
  }

  function finishAiStep(idx, output, skipped) {
    var iconEl = document.getElementById('ai-step-icon-' + idx);
    var descEl = document.getElementById('ai-step-desc-' + idx);
    var timeEl = document.getElementById('ai-step-time-' + idx);
    var outEl = document.getElementById('ai-step-out-' + idx);

    if (iconEl) {
      if (skipped) {
        iconEl.innerHTML = '<span style="color:var(--text-muted)">⏭</span>';
      } else {
        iconEl.innerHTML = '<span style="color:var(--green);font-size:14px">✓</span>';
      }
    }
    if (descEl) descEl.classList.remove('pending');
    if (timeEl && aiStepStartTimes[idx]) {
      var elapsed = ((Date.now() - aiStepStartTimes[idx]) / 1000).toFixed(1) + 's';
      timeEl.textContent = elapsed;
    }
    // Show output preview for FIX steps, or if output contains useful info
    if (outEl && output && !skipped) {
      var trimmed = output.length > 600 ? output.slice(0, 600) + '\n...' : output;
      outEl.textContent = trimmed;
      // For FIX steps, show output by default; for READ steps, hide behind toggle
      var stepRow = document.getElementById('ai-step-' + idx);
      var sType = stepTypes[idx] || 'read';
      if (sType === 'fix') {
        outEl.classList.add('visible');
      } else if (trimmed.length > 10) {
        // Add a toggle for READ output
        var toggle = document.createElement('button');
        toggle.className = 'ai-step-toggle';
        toggle.textContent = isZh ? '查看输出 ▾' : 'Show output ▾';
        toggle.addEventListener('click', function() {
          var showing = outEl.classList.toggle('visible');
          toggle.textContent = showing ? (isZh ? '收起 ▴' : 'Hide ▴') : (isZh ? '查看输出 ▾' : 'Show output ▾');
        });
        outEl.parentNode.insertBefore(toggle, outEl);
      }
    }
  }

  // Legacy compat — old read step functions now route to AI phase card
  function addReadStep(step, idx) { addAiStep(step, idx); }
  function doneReadStep(idx, skipped) { finishAiStep(idx, null, skipped); }

  function finishScanBlock() {
    // Stop elapsed timer and freeze the final time
    if (scanTimerInterval) { clearInterval(scanTimerInterval); scanTimerInterval = null; }
    var elapsed = scanStartTime ? ((Date.now() - scanStartTime) / 1000).toFixed(1) + 's' : '';
    var s = document.getElementById('scan-status');
    if (s) s.innerHTML = '<span style="font-size:16px;color:var(--green)">✓</span>';
    var t = document.getElementById('scan-title');
    if (t) t.textContent = T.scanned;
    var sub = document.getElementById('scan-sub');
    if (sub) sub.textContent = elapsed;
  }

  // ═══ Fix Step Cards ═══════════════════════════════════════════════════════
  function addFixCard(step, idx) {
    var card = document.createElement('div');
    card.className = 'fix-card'; card.id = 'step-' + idx;
    var badges = '<span class="badge badge-fix">fix</span>';
    if (step.risk === 'medium') badges += '<span class="badge badge-medium">medium risk</span>';
    if (step.risk === 'high') badges += '<span class="badge badge-high">⚠ high risk</span>';

    var reasoning = step.thinking || step.reason || '';
    var thinkHtml = '';
    if (reasoning) {
      thinkHtml = '<button class="fix-thinking-btn" id="think-btn-'+idx+'">' + T.showThinking + '</button>'
        + '<div class="fix-thinking-text" id="think-text-'+idx+'">' + esc(reasoning) + '</div>';
    }

    card.innerHTML = '<div class="fix-hd" onclick="this.parentElement.classList.toggle(\'open\')">'
      + '<div class="fix-icon">🔧</div>'
      + '<div class="fix-info">'
      +   '<div class="fix-title">' + esc(step.description || 'Running fix...') + '</div>'
      +   '<div class="fix-badges">' + badges + '</div>'
      + '</div>'
      + '<div class="fix-status" id="fix-st-'+idx+'"><div class="spin spin-sm"></div></div>'
      + '</div>'
      + '<div class="fix-detail" id="fix-det-'+idx+'">'
      + thinkHtml
      + (step.command ? '<div class="fix-cmd" translate="no">$ ' + esc(step.command) + '</div>' : '')
      + '<div id="fix-out-'+idx+'"></div>'
      + '</div>';
    feed.appendChild(card);

    if (reasoning) {
      document.getElementById('think-btn-'+idx).addEventListener('click', function() {
        var txt = document.getElementById('think-text-'+idx);
        var open = txt.style.display === 'block';
        txt.style.display = open ? 'none' : 'block';
        this.textContent = open ? T.showThinking : T.hideThinking;
      });
    }

    scrollDown();
    return card;
  }

  function finishFixCard(idx, output, skipped) {
    var st = document.getElementById('fix-st-' + idx);
    if (st) st.innerHTML = skipped ? '⏭' : '<span style="color:var(--green)">✓</span>';
    var area = document.getElementById('fix-out-' + idx);
    if (area && output && !skipped) {
      var trimmed = output.length > 900 ? output.slice(0, 900) + '\n...' : output;
      area.innerHTML = '<div class="fix-output-label">Output</div>'
        + '<div class="fix-output" translate="no">' + esc(trimmed) + '</div>';
    }
  }

  // ═══ Confirm Bar ══════════════════════════════════════════════════════════
  function addConfirmBar(step, idx) {
    // Attach to the AI step row, or fallback to old fix card
    var card = document.getElementById('ai-step-' + idx) || document.getElementById('step-' + idx);
    if (!card) return;
    var risk = step.risk || 'medium';
    var bar = document.createElement('div');
    bar.className = 'confirm-bar' + (risk === 'high' ? ' risk-high' : '');
    bar.id = 'cfm-' + idx;
    bar.style.borderRadius = '0 0 var(--radius-xs) var(--radius-xs)';
    bar.style.margin = '6px 0 2px';
    bar.innerHTML = '<span class="confirm-label">' + T.allowQ + '</span>'
      + '<button class="btn btn-green" id="cfm-y-'+idx+'">' + T.allow + '</button>'
      + '<button class="btn btn-ghost" id="cfm-n-'+idx+'">' + T.skip + '</button>';
    card.appendChild(bar);

    document.getElementById('cfm-y-'+idx).addEventListener('click', function() {
      var dt = _confirmShownAt ? Date.now() - _confirmShownAt : 0;
      ev('step_decided', { step_number: idx, decision: 'confirmed', decision_time_ms: dt });
      bar.remove();
      fetch('/api/confirm', { method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ sessionId: sessionId, confirmed: true }) });
    });
    document.getElementById('cfm-n-'+idx).addEventListener('click', function() {
      var dt = _confirmShownAt ? Date.now() - _confirmShownAt : 0;
      ev('step_decided', { step_number: idx, decision: 'skipped', decision_time_ms: dt });
      bar.remove();
      fetch('/api/confirm', { method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ sessionId: sessionId, confirmed: false }) });
    });
    scrollDown();
  }

  // ═══ Warning Cards ══════════════════════════════════════════════════════
  function dismissWarnCard(card) {
    var h = card.scrollHeight;
    card.style.maxHeight = h + 'px';
    card.style.overflow = 'hidden';
    card.style.opacity = '0';
    card.style.transform = 'translateX(8px)';
    setTimeout(function() {
      card.style.maxHeight = '0';
      card.style.marginBottom = '0';
      card.style.paddingTop = '0';
      card.style.paddingBottom = '0';
      setTimeout(function() { card.remove(); }, 350);
    }, 200);
  }

  function copyCmd(cmd, btn, origText) {
    navigator.clipboard.writeText(cmd).then(function() {
      mp('warning_fix_copy', { command: cmd });
      showToast(isZh ? '✓ 已复制到剪贴板' : '✓ Copied to clipboard');
      btn.textContent = T.copied;
      btn.classList.add('copied');
      setTimeout(function() { btn.textContent = origText; btn.classList.remove('copied'); }, 2200);
    }).catch(function() { showToast(isZh ? '请手动复制命令' : 'Please copy manually'); });
  }

  function createWarnings(warnings, title) {
    if (!warnings || warnings.length === 0) return null;

    var section = document.createElement('div');
    section.className = 'warnings-section';

    if (title) {
      var heading = document.createElement('div');
      heading.className = 'warnings-heading';
      heading.textContent = title;
      section.appendChild(heading);
    }

    for (var wi = 0; wi < warnings.length; wi++) {
      var w = warnings[wi];
      var isObj = typeof w === 'object' && w !== null;
      var text = isObj ? (w.text || '') : String(w);
      var rec = isObj ? (w.recommendation || 'review') : 'review';
      var fixCmd2 = isObj ? (w.fixCommand || null) : null;
      var reason = isObj ? (w.reason || '') : '';
      var actions = isObj ? (w.actions || null) : null;

      var icon = rec === 'fix' ? '🔧' : rec === 'ignore' ? '💡' : '👀';

      var card = document.createElement('div');
      card.className = 'wc wc-' + rec;

      // Header
      var hd = document.createElement('div');
      hd.className = 'wc-hd';
      hd.innerHTML = '<span class="wc-icon">' + icon + '</span>'
        + '<span class="wc-title">' + esc(text) + '</span>';

      if (rec === 'ignore') {
        hd.innerHTML += '<span class="wc-ignorable">' + T.ignorable + '</span>';
      }

      var dismissBtn = document.createElement('button');
      dismissBtn.className = 'wc-dismiss';
      dismissBtn.title = 'Dismiss';
      dismissBtn.textContent = '✕';
      (function(c) { dismissBtn.addEventListener('click', function() { dismissWarnCard(c); }); })(card);
      hd.appendChild(dismissBtn);
      card.appendChild(hd);

      // Reason
      if (reason) {
        var reasonEl = document.createElement('div');
        reasonEl.className = 'wc-reason';
        reasonEl.textContent = reason;
        card.appendChild(reasonEl);
      }

      // Actions array (choice buttons)
      if (actions && Array.isArray(actions) && actions.length > 0) {
        var actionsArea = document.createElement('div');
        actionsArea.className = 'wc-actions';
        for (var ai = 0; ai < actions.length; ai++) {
          var act = actions[ai];
          var actBtn = document.createElement('button');
          actBtn.className = 'wc-action-btn ' + (act.command ? 'wc-action-primary' : 'wc-action-secondary');
          actBtn.textContent = act.label || (act.command ? T.quickFix : T.skip);
          if (act.command) {
            (function(cmd, btn) {
              btn.addEventListener('click', function() { copyCmd(cmd, btn, btn.textContent); });
            })(act.command, actBtn);
          } else {
            (function(c) { actBtn.addEventListener('click', function() { dismissWarnCard(c); }); })(card);
          }
          actionsArea.appendChild(actBtn);
        }
        card.appendChild(actionsArea);
      }
      // Single fixCommand
      else if (fixCmd2) {
        if (rec === 'fix') {
          var fixArea = document.createElement('div');
          fixArea.className = 'wc-actions';
          var fixBtn = document.createElement('button');
          fixBtn.className = 'wc-action-btn wc-action-primary';
          fixBtn.textContent = T.quickFix;
          (function(cmd, btn) {
            btn.addEventListener('click', function() { copyCmd(cmd, btn, T.quickFix); });
          })(fixCmd2, fixBtn);
          fixArea.appendChild(fixBtn);
          card.appendChild(fixArea);
        } else {
          var codeArea = document.createElement('div');
          codeArea.className = 'wc-code-area';
          codeArea.setAttribute('translate', 'no');
          codeArea.innerHTML = '<code class="wc-code">' + esc(fixCmd2) + '</code>';
          var cpyBtn = document.createElement('button');
          cpyBtn.className = 'wc-copy';
          cpyBtn.textContent = '📋';
          cpyBtn.title = isZh ? '复制命令' : 'Copy command';
          (function(cmd, btn) {
            btn.addEventListener('click', function() {
              navigator.clipboard.writeText(cmd).then(function() {
                mp('warning_fix_copy', { command: cmd });
                btn.textContent = '✓'; btn.classList.add('copied');
                setTimeout(function() { btn.textContent = '📋'; btn.classList.remove('copied'); }, 2000);
              });
            });
          })(fixCmd2, cpyBtn);
          codeArea.appendChild(cpyBtn);
          card.appendChild(codeArea);
        }
      }

      section.appendChild(card);
    }

    return section;
  }

  // ═══ Feedback ═════════════════════════════════════════════════════════════
  function createFeedback() {
    var submitted = false;
    var div = document.createElement('div');
    div.className = 'fb-card';
    div.innerHTML = '<div class="fb-q">' + T.wasHelpful + '</div>'
      + '<div class="fb-btns" id="fb-btns">'
      +   '<button class="btn btn-ghost fb-btn" data-val="yes">' + T.feedbackYes + '</button>'
      +   '<button class="btn btn-ghost fb-btn" data-val="no">' + T.feedbackNo + '</button>'
      + '</div>'
      + '<div class="fb-done" id="fb-done"></div>';

    div.querySelectorAll('.fb-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (submitted) return;
        submitted = true;
        var val = btn.dataset.val;
        mp('feedback', { value: val });
        fetch('/api/feedback', { method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ feedback: val, sessionId: sessionId, sbSessionId: sbSessionId }) }).catch(function(){});

        var btns = div.querySelector('#fb-btns');
        btns.style.transition = 'opacity .22s ease, transform .22s ease';
        btns.style.opacity = '0'; btns.style.transform = 'translateY(-4px)';

        setTimeout(function() {
          btns.style.display = 'none';
          var done = div.querySelector('#fb-done');
          var contactHtml = val === 'no'
            ? '<div class="fb-contact">' + T.contact + '<br>WeChat: <b>oliver56666</b> · <a href="https://github.com/jjj5666/clawaid/issues" target="_blank">GitHub Issues</a></div>'
            : '';
          done.innerHTML = '<span class="fb-emoji">' + (val === 'yes' ? '🎉' : '🙏') + '</span>'
            + '<div class="fb-text">' + (val === 'yes' ? T.thanksYes : T.thanksNo) + '</div>'
            + contactHtml;
          done.classList.add('visible');
        }, 240);
      });
    });

    return div;
  }

  // ═══ Feedback Gate (shown before result) ═══════════════════════════════
  function showFeedbackGate(data, outcome) {
    finishScanBlock();
    // For healthy systems, skip the gate — user didn't have a problem to solve
    if (outcome === 'healthy') {
      showResult(data);
      return;
    }
    var isZh = /^zh/i.test(navigator.language || '');
    // Detect from existing T
    var qText = isZh ? '问题解决了吗？' : 'Did this solve your problem?';
    var yesText = isZh ? '✅ 解决了！' : '✅ Yes, fixed!';
    var noText = isZh ? '❌ 没有' : '❌ No';
    var detailLabel = isZh ? '能简单说说什么情况吗？（可选）' : 'What happened? (optional)';
    var skipText = isZh ? '跳过' : 'Skip';
    var submitText = isZh ? '提交' : 'Submit';

    var el = document.createElement('div');
    el.className = 'card feedback-gate';
    el.innerHTML = '<span class="fb-gate-emoji">🩺</span>'
      + '<div class="fb-gate-q">' + qText + '</div>'
      + '<div class="fb-gate-btns">'
      +   '<button class="btn fb-gate-btn fb-gate-btn-yes">' + yesText + '</button>'
      +   '<button class="btn fb-gate-btn fb-gate-btn-no">' + noText + '</button>'
      + '</div>'
      + '<div class="fb-gate-detail" style="display:none;">'
      +   '<div class="fb-gate-detail-label">' + detailLabel + '</div>'
      +   '<textarea rows="3" placeholder="..."></textarea>'
      +   '<div class="fb-gate-detail-row">'
      +     '<button class="btn btn-ghost fb-gate-skip">' + skipText + '</button>'
      +     '<button class="btn btn-accent fb-gate-submit">' + submitText + '</button>'
      +   '</div>'
      + '</div>';
    document.getElementById('feed').appendChild(el);
    scrollDown();

    function sendFb(val, detail) {
      ev('feedback', { value: val, detail: detail || null });
      fetch('/api/feedback', { method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ feedback: val, detail: detail || undefined, sessionId: sessionId, sbSessionId: sbSessionId }) }).catch(function(){});
    }

    el.querySelector('.fb-gate-btn-yes').addEventListener('click', function() {
      sendFb('yes');
      el.remove();
      showResult(data);
    });

    el.querySelector('.fb-gate-btn-no').addEventListener('click', function() {
      // Show detail textarea
      el.querySelector('.fb-gate-btns').style.display = 'none';
      el.querySelector('.fb-gate-detail').style.display = 'block';
      var ta = el.querySelector('textarea');
      setTimeout(function() { ta.focus(); }, 100);
    });

    el.querySelector('.fb-gate-skip').addEventListener('click', function() {
      sendFb('no');
      el.remove();
      showResult(data);
    });

    el.querySelector('.fb-gate-submit').addEventListener('click', function() {
      var detail = el.querySelector('textarea').value.trim();
      sendFb('no', detail);
      el.remove();
      showResult(data);
    });
  }

  // ═══ Result Pages ═════════════════════════════════════════════════════════
  function showResult(data) {
    finishScanBlock();

    var warnings = Array.isArray(data.warnings) ? data.warnings : [];
    var variant;
    if      (data.fixed)                            variant = 'fixed';
    else if (data.degraded)                         variant = 'degraded';
    else if (data.healthy && warnings.length === 0) variant = 'healthy-clean';
    else if (data.healthy)                          variant = 'healthy-warnings';
    else                                            variant = 'not-fixed';

    var card = document.createElement('div');
    card.className = 'result-card';

    if (variant === 'fixed') {
      triggerConfetti();
      var problemText = data.problem || null;
      var fixText = data.fix || null;
      var metaHtml = '';
      if (problemText || fixText) {
        metaHtml = '<div class="result-meta">';
        if (problemText) {
          metaHtml += '<div class="rmr"><span class="rmr-label">' + T.problem + ':</span><span class="rmr-value">' + esc(problemText) + '</span></div>';
        }
        if (fixText) {
          metaHtml += '<div class="rmr"><span class="rmr-label">' + T.fixedLabel + ':</span><span class="rmr-value">' + esc(fixText) + '</span></div>';
        }
        metaHtml += '</div>';
      }
      card.innerHTML = '<span class="result-icon">✅</span>'
        + '<div class="result-title">' + T.fixed + '</div>'
        + metaHtml;
      var ws = createWarnings(warnings, T.findingsTitle);
      if (ws) card.appendChild(ws);
      card.appendChild(createFeedback());

    } else if (variant === 'healthy-clean') {
      card.innerHTML = '<span class="result-icon">💚</span>'
        + '<div class="result-title">' + T.allClear + '</div>';

    } else if (variant === 'healthy-warnings') {
      card.innerHTML = '<span class="result-icon">💚</span>'
        + '<div class="result-title">' + T.allClear + '</div>';
      var ws2 = createWarnings(warnings, T.suggestionsTitle);
      if (ws2) card.appendChild(ws2);
      card.appendChild(createFeedback());

    } else if (variant === 'degraded') {
      card.innerHTML = '<span class="result-icon">⚠️</span>'
        + '<div class="result-title">' + T.degradedTitle + '</div>'
        + ((data.problem || data.summary)
          ? '<div class="problem-box problem-box-amber"><div class="problem-box-label">' + T.problem + '</div><div>' + esc(data.problem || data.summary) + '</div></div>'
          : '');
      var ws3 = createWarnings(warnings, null);
      if (ws3) card.appendChild(ws3);
      var contact = document.createElement('div');
      contact.className = 'contact-block';
      contact.innerHTML = T.contact + ' WeChat: <b>oliver56666</b> · <a href="https://github.com/jjj5666/clawaid/issues" target="_blank">GitHub Issues</a>';
      card.appendChild(contact);
      card.appendChild(createFeedback());

    } else {
      // not-fixed
      card.innerHTML = '<span class="result-icon">😔</span>'
        + '<div class="result-title">' + T.notFixed + '</div>'
        + ((data.problem || data.summary)
          ? '<div class="problem-box problem-box-red"><div class="problem-box-label">' + T.problem + '</div><div>' + esc(data.problem || data.summary) + '</div></div>'
          : '');
      var contact2 = document.createElement('div');
      contact2.className = 'contact-block';
      contact2.innerHTML = T.contact + ' WeChat: <b>oliver56666</b> · <a href="https://github.com/jjj5666/clawaid/issues" target="_blank">GitHub Issues</a>';
      card.appendChild(contact2);
    }

    // Scan again / try again
    var again = document.createElement('button');
    again.className = 'btn btn-ghost btn-full';
    again.style.marginTop = '16px';
    again.textContent = variant === 'not-fixed' ? T.tryAgain : T.scanAgain;
    again.addEventListener('click', function() { location.reload(); });
    card.appendChild(again);

    feed.appendChild(card);
    scrollDown();
  }

  // ═══ Error Card ═══════════════════════════════════════════════════════════
  function showErrorCard(msg) {
    var card = document.createElement('div');
    card.className = 'result-card';
    card.innerHTML = '<span class="result-icon">❌</span>'
      + '<div class="result-title">' + T.error + '</div>'
      + '<div style="font-size:14px;color:var(--text-secondary);margin-bottom:18px;">' + esc(msg || 'Unknown error') + '</div>';
    var btn = document.createElement('button');
    btn.className = 'btn btn-ghost btn-full';
    btn.textContent = T.retry;
    btn.addEventListener('click', function() { location.reload(); });
    card.appendChild(btn);
    feed.appendChild(card);
    scrollDown();
  }

  // ═══ Paywall (v4: ClawAid is now completely FREE — this should never be shown) ══
  function showPaywall(data) {
    // v4: ClawAid is completely free. If this function is called, show a friendly message.
    var freeMsg = isZh
      ? '<div style="text-align:center;padding:40px 20px;"><div style="font-size:48px;margin-bottom:16px;">🎉</div><h2 style="margin-bottom:12px;">ClawAid 完全免费！</h2><p style="color:var(--text-secondary);">请重新运行 <code>npx clawaid@latest</code> 获取最新版本</p></div>'
      : '<div style="text-align:center;padding:40px 20px;"><div style="font-size:48px;margin-bottom:16px;">🎉</div><h2 style="margin-bottom:12px;">ClawAid is Completely Free!</h2><p style="color:var(--text-secondary);">Please run <code>npx clawaid@latest</code> to get the latest version</p></div>';
    resultEl.innerHTML = freeMsg;
    return; // Skip all payment UI below

    // === Legacy payment code kept for reference (unreachable) ===
    var STRIPE_URL = 'https://buy.stripe.com/bJe8wReoT7oZ9XH7tU0oM02';
    var payMethod = data.payMethod || (data.isChinese ? 'xunhupay' : 'stripe');
    if (isZh && payMethod !== 'xunhupay') payMethod = 'xunhupay';
    var isCN = payMethod === 'xunhupay';
    var pricing = data.pricing || {};
    var fixPrice = (pricing.fixOnce && pricing.fixOnce.price) || (isCN ? '¥4.99' : '$0.99');
    var subPrice = (pricing.subscription && pricing.subscription.price) || (isCN ? '¥49.99/月' : '$9.99/mo');

    // v3: Show AI's pending fix diagnosis
    var diagnosisHtml = '';
    var pendingFix = data.pendingFix;
    if (pendingFix && pendingFix.description) {
      var cmdHtml = '';
      if (pendingFix.command) {
        cmdHtml = '<div style="margin-top:8px;padding:8px 10px;background:var(--surface-alt);border-radius:6px;font-family:var(--mono);font-size:11px;color:var(--text-secondary);word-break:break-all;">'
          + '🔧 ' + (isZh ? '修复方案：' : 'Fix: ') + '<code>' + esc(pendingFix.command) + '</code></div>';
      }
      diagnosisHtml = '<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:12px;">'
        + '<div style="font-weight:700;font-size:14px;margin-bottom:8px;">'
        + (isZh ? '🔍 已找到问题：' : '🔍 Issue found:')
        + '</div>'
        + '<div style="display:flex;align-items:flex-start;gap:8px;">'
        + '<span style="flex-shrink:0;">⚠️</span>'
        + '<div style="font-size:13px;">' + esc(pendingFix.description) + '</div>'
        + '</div>'
        + cmdHtml
        + '</div>';
    }

    // Also show rule findings if available
    var findings = data.findings || [];
    if (!pendingFix && findings.length > 0) {
      var items = findings.map(function(f) {
        return '<div style="display:flex;align-items:flex-start;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);">'
          + '<span style="flex-shrink:0;">⚠️</span>'
          + '<div><div style="font-weight:600;font-size:13px;">' + esc(f.title) + '</div></div>'
          + '</div>';
      }).join('');
      diagnosisHtml = '<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:12px;">'
        + '<div style="font-weight:700;font-size:14px;margin-bottom:8px;">'
        + (isZh ? '🔍 扫描发现以下问题：' : '🔍 Issues found:')
        + '</div>' + items + '</div>';
    }

    // Fix-once button
    var buyBtnHtml;
    if (isCN) {
      buyBtnHtml = '<button class="btn btn-primary btn-full" id="pw-buy" style="margin-bottom:0;">🔧 ' + esc(fixPrice) + ' — ' + (isZh ? '本次彻底解决' : 'Fix everything now') + '</button>'
        + '<div style="text-align:center;font-size:12px;color:var(--text-muted);margin-top:4px;">' + (isZh ? '所有问题一次修完 · 修不好带截图找客服退款' : 'Fix all issues · screenshot + refund if not fixed') + '</div>'
        + '<div id="pw-xhp-loading" style="display:none;text-align:center;padding:12px;color:var(--text-muted);font-size:13px;">' + (isZh ? '正在创建订单...' : 'Creating order...') + '</div>'
        + '<div id="pw-xhp-qr" style="display:none;text-align:center;padding:12px;">'
        + '<p style="font-size:13px;color:var(--text-muted);margin-bottom:8px;">' + (isZh ? '扫码支付 ' : 'Scan to pay ') + esc(fixPrice) + '</p>'
        + '<img id="pw-xhp-qr-img" src="" style="max-width:200px;border-radius:8px;border:1px solid var(--border);" />'
        + '</div>';
    } else {
      buyBtnHtml = '<a href="'+STRIPE_URL+'" target="_blank" class="btn btn-primary btn-full" id="pw-buy" style="text-decoration:none;margin-bottom:0;">🔧 ' + esc(fixPrice) + ' — Fix everything now</a>'
        + '<div style="text-align:center;font-size:12px;color:var(--text-muted);margin-top:4px;">Fix all issues · screenshot + refund if not fixed</div>';
    }

    // Waitlist button
    var waitlistHtml = '<div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);">'
      + '<button class="btn btn-ghost btn-full" id="pw-waitlist" style="margin-bottom:4px;">🛡️ ' + esc(subPrice) + ' — ' + (isZh ? '持续守护' : 'Always Protected') + '</button>'
      + '<div style="text-align:center;font-size:12px;color:var(--text-muted);line-height:1.5;">' + (isZh ? 'OpenClaw 生命周期管家：安装 · 升级 · 修复 · API管理 · 记忆管理<br>7×24 持续健康保障 · 加入等待名单' : 'OpenClaw lifecycle butler: install · upgrade · fix · API mgmt · memory mgmt<br>24/7 health monitoring · join waitlist') + '</div>'
      + '<div id="pw-waitlist-form" style="display:none;margin-top:8px;">'
      + '<input class="pw-input" id="pw-waitlist-email" type="email" placeholder="' + (isZh ? '输入邮箱加入等待名单' : 'Email to join waitlist') + '" />'
      + '<button class="btn btn-ghost btn-full" id="pw-waitlist-submit" style="margin-top:6px;">' + (isZh ? '加入等待名单' : 'Join Waitlist') + '</button>'
      + '<div id="pw-waitlist-msg" style="text-align:center;font-size:12px;margin-top:4px;"></div>'
      + '</div></div>';

    var div = document.createElement('div');
    div.className = 'card pw-card';
    div.innerHTML = '<div class="pw-hd">'
      + '<span class="pw-emoji">🩺</span>'
      + '<div class="pw-title">' + (isZh ? '🎯 问题已定位，修复方案已就绪' : '🎯 Issue identified, fix ready') + '</div>'
      + '<div class="pw-sub">' + (isZh ? '付费解锁 → AI 自动执行修复 → 30秒搞定（自己排查可能要 1-2 小时）' : 'Pay to unlock → AI auto-fixes → 30s done (vs 1-2 hours manual debugging)') + '</div>'
      + '</div>'
      + diagnosisHtml
      + buyBtnHtml
      + waitlistHtml
      + '<div class="pw-auto-detect" id="pw-auto">'
      + '<div class="spin spin-sm" style="vertical-align:middle;margin-right:6px;"></div>'
      + '<span>' + T.pwWaiting + '</span>'
      + '</div>'
      + '<hr class="pw-divider">'
      + '<details style="margin-bottom:8px;">'
      + '<summary style="font-size:13px;color:var(--text-secondary);cursor:pointer;user-select:none;margin-bottom:12px;">' + T.pwHaveToken + '</summary>'
      + '<input class="pw-input" id="pw-token" type="text" placeholder="' + T.pwTokenHint + '" autocomplete="off" />'
      + '<button class="btn btn-ghost btn-full" id="pw-activate" style="margin-top:6px;">' + T.pwActivate + '</button>'
      + '</details>'
      + '<div class="pw-msg" id="pw-msg"></div>'
      + '<div class="pw-contact">' + (isZh ? '修不好？截图发微信 <b>oliver56666</b> 退款' : 'Not fixed? Screenshot + email <b>ollie56666@gmail.com</b> for refund') + '</div>';
    feed.appendChild(div);

    // Fetch fingerprint for buy URL (Stripe) or xunhupay order creation
    var _pwFingerprint = '';
    var _fpReady = false;
    // Disable buy button until fingerprint is loaded
    var _buyBtn = document.getElementById('pw-buy');
    if (_buyBtn && !isCN) { _buyBtn.style.opacity = '0.5'; _buyBtn.style.pointerEvents = 'none'; }
    fetch('/api/fingerprint').then(function(r){return r.json();}).then(function(d) {
      _pwFingerprint = d.fingerprint || '';
      _fpReady = true;
      if (!isCN) {
        var btn = document.getElementById('pw-buy');
        if (btn && d.fingerprint) {
          btn.href = STRIPE_URL + '?client_reference_id=' + encodeURIComponent(d.fingerprint);
          btn.style.opacity = '1';
          btn.style.pointerEvents = 'auto';
        }
      }
    }).catch(function(){ _fpReady = true; });

    // Auto-poll after buy (works for both Stripe and Xunhupay)
    var pollTimer = null, pollCount = 0, MAX_POLLS = 120;
    function startPolling() {
      var detect = document.getElementById('pw-auto');
      if (detect) detect.style.display = 'block';
      pollCount = 0;
      pollTimer = setInterval(function() {
        pollCount++;
        if (pollCount > MAX_POLLS) {
          clearInterval(pollTimer);
          if (detect) detect.innerHTML = '<span style="color:var(--text-muted);">' + T.pwAutoTimeout + '</span>';
          return;
        }
        fetch('/api/poll-token').then(function(r){return r.json();}).then(function(r) {
          if (r.found && r.token) {
            clearInterval(pollTimer);
            mp('auto_activate_success');
            if (detect) detect.innerHTML = '<span style="color:var(--green);">' + T.pwPaySuccess + '</span>';
            fetch('/api/redeem', { method:'POST', headers:{'Content-Type':'application/json'},
              body: JSON.stringify({token:r.token}) }).catch(function(){});
            setTimeout(function() { location.reload(); }, 1500);
          }
        }).catch(function(){});
      }, 5000);
    }

    document.getElementById('pw-buy').addEventListener('click', function(e) {
      mp('buy_clicked');
      if (isCN) {
        e.preventDefault();
        // Create xunhupay order
        var btn = document.getElementById('pw-buy');
        var loading = document.getElementById('pw-xhp-loading');
        var qrDiv = document.getElementById('pw-xhp-qr');
        btn.style.display = 'none';
        loading.style.display = 'block';

        fetch('https://api.clawaid.app/create-order/xunhupay', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fingerprint: _pwFingerprint }),
        }).then(function(r){return r.json();}).then(function(data) {
          loading.style.display = 'none';
          if (data.error) { btn.style.display = 'block'; alert(data.error); return; }
          if (/Mobi|Android/i.test(navigator.userAgent) && data.url) {
            window.location.href = data.url;
          } else if (data.url_qrcode) {
            document.getElementById('pw-xhp-qr-img').src = data.url_qrcode;
            qrDiv.style.display = 'block';
          } else if (data.url) {
            window.location.href = data.url;
          }
          startPolling();
        }).catch(function(err) {
          loading.style.display = 'none';
          btn.style.display = 'block';
          alert('创建订单失败: ' + (err.message || ''));
        });
      } else {
        // Stripe — just start polling after click
        setTimeout(startPolling, 3000);
      }
    });

    // Manual token
    var activateBtn = document.getElementById('pw-activate');
    var tokenInput = document.getElementById('pw-token');
    var msgEl = document.getElementById('pw-msg');

    function doActivate() {
      var token = tokenInput.value.trim();
      if (!token) { msgEl.style.color='var(--red)'; msgEl.textContent=T.pwEnterToken; return; }
      mp('token_redeem_attempt');
      msgEl.style.color='var(--text-muted)'; msgEl.textContent=T.pwChecking;
      fetch('/api/redeem', { method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({token:token}) })
        .then(function(r){return r.json();})
        .then(function(r) {
          if (r.valid) {
            if (pollTimer) clearInterval(pollTimer);
            mp('token_redeem_success');
            msgEl.style.color='var(--green)'; msgEl.textContent=T.pwSuccess;
            setTimeout(function() { location.reload(); }, 1500);
          } else {
            mp('token_redeem_fail');
            msgEl.style.color='var(--red)'; msgEl.textContent=T.pwInvalid;
          }
        })
        .catch(function() { msgEl.style.color='var(--red)'; msgEl.textContent=T.pwNetErr; });
    }
    activateBtn.addEventListener('click', doActivate);
    tokenInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') doActivate(); });

    // Waitlist
    var wlBtn = document.getElementById('pw-waitlist');
    var wlForm = document.getElementById('pw-waitlist-form');
    if (wlBtn && wlForm) {
      wlBtn.addEventListener('click', function() {
        wlForm.style.display = wlForm.style.display === 'none' ? 'block' : 'none';
        ev('waitlist_clicked');
      });
      var wlSubmit = document.getElementById('pw-waitlist-submit');
      var wlEmail = document.getElementById('pw-waitlist-email');
      var wlMsg = document.getElementById('pw-waitlist-msg');
      if (wlSubmit) {
        wlSubmit.addEventListener('click', function() {
          var email = wlEmail ? wlEmail.value.trim() : '';
          if (!email || email.indexOf('@') < 0) {
            if (wlMsg) { wlMsg.style.color = 'var(--red)'; wlMsg.textContent = isZh ? '请输入有效邮箱' : 'Please enter a valid email'; }
            return;
          }
          wlSubmit.disabled = true;
          fetch('/api/waitlist', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ email: email }) })
            .then(function() {
              if (wlMsg) { wlMsg.style.color = 'var(--green)'; wlMsg.textContent = isZh ? '✅ 已加入等待名单！' : '✅ You\'re on the list!'; }
              ev('waitlist_joined', { email: email });
            })
            .catch(function() {
              if (wlMsg) { wlMsg.style.color = 'var(--red)'; wlMsg.textContent = isZh ? '网络错误，请重试' : 'Network error, try again'; }
              wlSubmit.disabled = false;
            });
        });
      }
    }

    scrollDown();
  }

  // ═══ Description Input ════════════════════════════════════════════════════
  function showDescInput(data) {
    var screenshotData = null;

    var div = document.createElement('div');
    div.className = 'card input-card';
    div.id = 'desc-input-card';
    div.innerHTML = '<div class="input-title">' + T.whatsWrong + '</div>'
      + '<div class="input-hint">' + T.descHint + '</div>'
      + '<div class="input-textarea-wrap">'
      +   '<textarea class="input-textarea" id="desc-text" placeholder="' + T.descPlaceholder + '"></textarea>'
      +   '<button class="input-camera" id="desc-cam" title="' + (isZh ? '添加截图' : 'Add screenshot') + '">📷</button>'
      +   '<input type="file" id="ss-input" accept="image/*" style="display:none;" />'
      + '</div>'
      + '<div class="ss-preview" id="ss-preview">'
      +   '<img id="ss-thumb" src="" alt="" />'
      +   '<span class="ss-preview-name">' + (isZh ? '截图已附加' : 'Screenshot attached') + '</span>'
      +   '<button class="ss-preview-rm" id="ss-rm" title="Remove">✕</button>'
      + '</div>'
      + '<div class="btn-row">'
      +   '<button class="btn btn-primary" id="btn-send" disabled>' + T.sendDiagnose + '</button>'
      +   '<button class="btn btn-green" id="btn-skip">' + T.justScan + '</button>'
      + '</div>';
    feed.appendChild(div);
    scrollDown();

    var textarea = document.getElementById('desc-text');
    var camBtn = document.getElementById('desc-cam');
    var fileInput = document.getElementById('ss-input');
    var prevRow = document.getElementById('ss-preview');
    var thumb = document.getElementById('ss-thumb');
    var rmBtn = document.getElementById('ss-rm');
    var sendBtn = document.getElementById('btn-send');
    var skipBtn = document.getElementById('btn-skip');

    function updateSend() { sendBtn.disabled = textarea.value.trim().length === 0; }
    textarea.addEventListener('input', updateSend);

    function handleFile(file) {
      if (!file || !file.type.startsWith('image/')) return;
      if (file.size > 5 * 1024 * 1024) { showToast(isZh ? '图片过大（最大 5MB）' : 'Image too large (max 5MB)'); return; }
      var reader = new FileReader();
      reader.onload = function(e) {
        screenshotData = e.target.result;
        thumb.src = screenshotData;
        prevRow.classList.add('visible');
        camBtn.classList.add('has-img');
      };
      reader.readAsDataURL(file);
    }

    camBtn.addEventListener('click', function(e) { e.preventDefault(); fileInput.click(); });
    fileInput.addEventListener('change', function(e) { if (e.target.files[0]) handleFile(e.target.files[0]); });
    rmBtn.addEventListener('click', function() {
      screenshotData = null; prevRow.classList.remove('visible');
      thumb.src = ''; camBtn.classList.remove('has-img'); fileInput.value = '';
    });

    var wrap = div.querySelector('.input-textarea-wrap');
    wrap.addEventListener('dragover', function(e) { e.preventDefault(); textarea.style.borderColor = 'var(--accent)'; });
    wrap.addEventListener('dragleave', function() { textarea.style.borderColor = ''; });
    wrap.addEventListener('drop', function(e) {
      e.preventDefault(); textarea.style.borderColor = '';
      if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
    });

    function onPaste(e) {
      var items = e.clipboardData && e.clipboardData.items;
      if (!items) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].type.startsWith('image/')) { handleFile(items[i].getAsFile()); break; }
      }
    }
    document.addEventListener('paste', onPaste);

    function submit(desc) {
      document.removeEventListener('paste', onPaste);
      div.remove();
      fetch('/api/input', { method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ sessionId: sessionId, field: 'userDescription', value: desc || '', screenshot: screenshotData || undefined }) });
    }

    sendBtn.addEventListener('click', function() {
      mp('user_input', { type: 'description', has_screenshot: !!screenshotData });
      submit(textarea.value.trim());
    });
    skipBtn.addEventListener('click', function() {
      mp('user_input', { type: 'skip' });
      submit('');
    });
    textarea.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey) && textarea.value.trim()) {
        mp('user_input', { type: 'description', has_screenshot: !!screenshotData });
        submit(textarea.value.trim());
      }
    });
    textarea.focus();
  }

  // ═══ SSE ══════════════════════════════════════════════════════════════════
  var _sseRetries = 0;
  var _sseMaxRetries = 3;
  var _sseLastDataAt = 0;

  function startDiagnosis() {
    startScreen.classList.add('hidden');
    feed.classList.remove('hidden');
    feed.innerHTML = '';
    currentStepIndex = -1;
    scanBlockAdded = false;
    _sseRetries = 0;

    connectSSE();
  }

  function connectSSE() {
    var lang = isZh ? 'zh' : 'en';
    eventSource = new EventSource('/api/diagnose?lang=' + lang);
    _sseLastDataAt = Date.now();

    eventSource.onmessage = function(e) {
      _sseLastDataAt = Date.now();
      _sseRetries = 0; // reset retries on any successful message
      var msg;
      try { msg = JSON.parse(e.data); } catch(x) { return; }
      if (msg.sessionId) sessionId = msg.sessionId;
      onEvent(msg.type, msg.data || {});
    };

    eventSource.onerror = function() {
      var terminal = ['fixed','not_fixed','healthy','degraded','paywall','error'];
      var currentState = document.body.dataset.state || '';

      // If we're in a terminal state, just clean up — no retry needed
      if (terminal.indexOf(currentState) !== -1) {
        if (eventSource) { eventSource.close(); eventSource = null; }
        return;
      }

      // SSE can fire transient errors (browser reconnecting) — don't panic immediately.
      // If EventSource is CONNECTING (readyState=0), the browser is auto-reconnecting.
      if (eventSource && eventSource.readyState === 0) {
        // Browser is reconnecting on its own — but this creates a NEW /api/diagnose
        // call which starts a new session. We need to close and handle manually.
      }

      if (eventSource) { eventSource.close(); eventSource = null; }

      _sseRetries++;
      if (_sseRetries <= _sseMaxRetries) {
        // Retry after a short delay (exponential backoff: 2s, 4s, 8s)
        var delay = Math.min(2000 * Math.pow(2, _sseRetries - 1), 8000);
        setTimeout(function() {
          // Only reconnect if still not in a terminal state
          if (terminal.indexOf(document.body.dataset.state || '') === -1) {
            connectSSE();
          }
        }, delay);
        return;
      }

      // Exhausted retries — show connection lost
      var card = document.createElement('div');
      card.className = 'result-card';
      card.innerHTML = '<span class="result-icon">⚠️</span>'
        + '<div class="result-title">' + T.connLost + '</div>'
        + '<div style="font-size:14px;color:var(--text-secondary);margin-bottom:18px;">' + T.serverStopped + '</div>';
      var btn = document.createElement('button');
      btn.className = 'btn btn-ghost btn-full';
      btn.textContent = T.retry;
      btn.addEventListener('click', function() { location.reload(); });
      card.appendChild(btn);
      feed.appendChild(card);
      scrollDown();
    };
  }

  function onEvent(type, data) {
    switch (type) {

      case 'session_start':
        sessionId = data.sessionId || sessionId;
        break;

      case 'state_change':
        _currentState = data.state;
        document.body.dataset.state = data.state;
        if (data.state === 'observing' && !scanBlockAdded) {
          addScanBlock();
          scanBlockAdded = true;
        }
        if (data.state === 'running') {
          finishScanBlock();
        }
        break;

      case 'progress':
        updateScanProgress(data);
        break;

      case 'step_start': {
        currentStepIndex = data.index;
        _currentStep = data.index;
        var step = data.step || {};
        stepTypes[data.index] = step.type || 'read';
        ev('step_viewed', { step_number: data.index, type: step.type, risk: step.risk || 'low' });

        // All steps (READ + FIX) go into the AI phase card
        addAiStep(step, data.index);
        break;
      }

      case 'step_done': {
        var idx = data.index;
        var sType = stepTypes[idx] || 'read';
        var stepData = data.step || {};
        finishAiStep(idx, data.output, data.skipped);
        break;
      }

      case 'confirm_needed':
        _confirmShownAt = Date.now();
        addConfirmBar(data.step || {}, currentStepIndex);
        break;

      case 'complete': {
        if (eventSource) { eventSource.close(); eventSource = null; }
        _sessionEnded = true;
        sbSessionId = data.sbSessionId || null;
        finishAiPhaseCard();
        var outcome = data.fixed ? 'fixed'
          : data.degraded ? 'degraded'
          : data.healthy  ? 'healthy'
          : 'not_fixed';
        var durMs = _scanStartTime ? Date.now() - _scanStartTime : 0;
        ev('scan_complete', { outcome: outcome, steps: currentStepIndex + 1, duration_ms: durMs });
        showFeedbackGate(data, outcome);
        break;
      }

      case 'paywall':
        if (eventSource) { eventSource.close(); eventSource = null; }
        _sessionEnded = true;
        ev('paywall_shown');
        showPaywall(data);
        break;

      case 'request_input':
        if (data.field === 'userDescription') showDescInput(data);
        break;

      case 'error':
        showErrorCard(data.message);
        scrollDown();
        break;
    }
  }

  // ═══ Session tracking ═══════════════════════════════════════════════════
  var _scanStartTime = null;
  var _currentStep = 0;
  var _confirmShownAt = 0;
  var _currentState = 'idle';
  var _sessionEnded = false;

  window.addEventListener('beforeunload', function() {
    if (!_scanStartTime || _sessionEnded) return;
    navigator.sendBeacon('/api/event', JSON.stringify({
      event: 'session_end',
      data: { reason: 'page_closed', duration_ms: Date.now() - _scanStartTime, steps_completed: _currentStep, closed_at_state: _currentState || 'unknown' },
      ts: Date.now()
    }));
  });

  // ═══ Boot ═════════════════════════════════════════════════════════════════
  document.getElementById('btn-start').addEventListener('click', function() {
    _scanStartTime = Date.now();
    ev('scan_start');
    startDiagnosis();
  });

})();
</script>
</body>
</html>
